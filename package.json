{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "build": "npm run build:electron && make entrypoint && npm run build:web",
    "build:codegen": "npm run gen",
    "build:web": "node ./scripts/build-browser",
    "build:electron": "node ./scripts/build-electron",
    "build:gopherjs": "node ./scripts/build-runtime-gopherjs",
    "build:wasm": "node ./scripts/build-runtime-wasm",
    "serve": "node ./scripts/serve-browser",
    "start": "npm run start:web",
    "start:electron": "make start-electron",
    "start:web": "npm run serve",
    "debug:electron": "cd ./entrypoint/electron-dev && dlv debug",
    "codegen": "npm run gen",
    "gen": "make genproto",
    "format": "prettier --write './web/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "check": "npm run typecheck && npm run lint",
    "depcheck": "depcheck",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./web",
    "precommit": "npm run format",
    "prepare": "husky install && patch-package && go mod vendor"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "devDependencies": {
    "@types/random-string": "^0.0.28",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "depcheck": "^1.4.3",
    "electron": "^19.0.7",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard-with-typescript": "^21.0.1",
    "husky": "^8.0.1",
    "patch-package": "^6.4.7",
    "prettier": "^2.7.1",
    "pumpify": "^2.0.1",
    "ts-poet": "^4.15.0",
    "ts-proto": "^1.117.0",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@fontsource/open-sans": "^4.5.10",
    "@fontsource/raleway": "^4.5.9",
    "@libp2p/logger": "^2.0.0",
    "@libp2p/mplex": "^4.0.0",
    "browser-readablestream-to-it": "^1.0.3",
    "console": "^0.7.2",
    "idb": "^7.0.2",
    "it-first": "^1.0.7",
    "it-length-prefixed": "^7.0.1",
    "it-pipe": "^2.0.3",
    "it-pushable": "^3.0.0",
    "it-stream-types": "^1.0.4",
    "long": "^5.2.0",
    "protobufjs": "^6.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "starpc": "^0.7.0",
    "workbox-window": "^6.5.3"
  }
}
