{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperturerobotics.com",
    "url": "http://aperturerobotics.com"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperturerobotics.com",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "build": "snowpack build",
    "build:codegen": "npm run build:js:proto",
    "build:electron": "node ./scripts/build-electron-js",
    "build:gopherjs": "node ./scripts/build-runtime-gopherjs",
    "build:js:proto": "./scripts/compile-proto-js.bash",
    "build:wasm": "node ./scripts/build-runtime-wasm",
    "debug:electron": "cd ./target/electron-dev && dlv debug",
    "format": "prettier --write './{src,target}/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "gen": "make genproto",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./src",
    "precommit": "lint-staged",
    "prepare": "husky install",
    "serve": "cd ./toys/serve && go run -v ./",
    "start": "npm run start:web",
    "start:electron": "npm run build:electron && cd ./target/electron-dev && go run -trimpath -v ./",
    "start:web": "snowpack dev",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,css,html}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "dependencies": {
    "@chakra-ui/react": "^1.6.5",
    "@emotion/react": "^11.4.0",
    "@emotion/styled": "^11.3.0",
    "@fontsource/open-sans": "^4.5.0",
    "@fontsource/raleway": "^4.5.0",
    "framer-motion": "^4.1.17",
    "geopattern": "^1.2.3",
    "random-string": "^0.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-icons": "^4.2.0",
    "rgraphql": "^1.0.4",
    "wasm-feature-detect": "^1.2.11"
  },
  "devDependencies": {
    "@snowpack/plugin-react-refresh": "^2.5.0",
    "@types/geopattern": "^1.2.5",
    "@types/random-string": "^0.0.28",
    "@types/react": "^17.0.15",
    "@types/react-dom": "^17.0.9",
    "@types/snowpack-env": "^2.3.4",
    "@typescript-eslint/eslint-plugin": "^4.28.4",
    "@typescript-eslint/parser": "^4.28.4",
    "electron": "^13.1.8",
    "electron-snowpack": "^0.12.0",
    "eslint": "^7.31.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-standard-with-typescript": "^20.0.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.1",
    "lint-staged": "^10.2.11",
    "prettier": "^2.0.5",
    "pumpify": "^2.0.1",
    "rimraf": "^3.0.2",
    "snowpack": "^3.8.1-pre.0",
    "source-map-loader": "^1.0.0",
    "split2": "^3.2.2",
    "through2-filter": "^3.0.0",
    "through2-map": "^3.0.0",
    "ts-proto": "^1.82.5",
    "tslint": "^6.1.2",
    "tslint-config-prettier": "^1.17.0",
    "tslint-react": "^5.0.0",
    "typescript": "^3.9.5"
  }
}
