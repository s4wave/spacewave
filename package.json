{
  "name": "@aperturerobotics/hydra",
  "description": "Cross-platform peer-to-peer communications.",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/hydra.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit false --outDir ./dist/",
    "check": "bun run typecheck",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "deps": "depcheck --ignore-patterns=.eslintrc.cjs,package.json --ignores depcheck,rimraf,prettier,typescript,starpc,@go/github.com,@aptre/common",
    "codegen": "bun run gen",
    "ci": "bun run build && bun run lint:js && bun run lint:go",
    "format": "bun run format:js && bun run format:go",
    "format:js": "prettier --write './!(vendor|dist)/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "format:go": "bun run go:aptre -- format",
    "gen": "bun run go:aptre -- generate",
    "gen:force": "bun run go:aptre -- generate --force",
    "test": "bun run test:go && bun run test:js && bun run check",
    "test:go": "bun run go:aptre -- test",
    "test:js": "vitest run && bun run typecheck",
    "lint": "bun run lint:go && bun run lint:js",
    "lint:go": "bun run go:aptre -- lint",
    "lint:js": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.cjs ./",
    "prepare": "go mod vendor && rimraf ./.tools",
    "go:aptre": "go run -mod=mod github.com/aperturerobotics/common/cmd/aptre",
    "precommit": "bun run format"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aptre/common": "^0.26.11",
    "depcheck": "^1.4.7",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "^0.5.2",
    "starpc": "^0.42.0"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "0.5.2"
  }
}
