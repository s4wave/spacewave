{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/bldr.git"
  },
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "clean": "rimraf ./.bldr",
    "go:run": "cross-env GOOS= GOARCH= go run -v -mod=readonly",
    "bldr": "npm run go:run -- github.com/aperturerobotics/bldr/cmd/bldr --bldr-src-path=../../",
    "serve": "npm run start:web",
    "start": "npm run start:web",
    "start:native": "npm run bldr -- start native",
    "start:native:release": "npm run build:release && cd ./.bldr/build/native/bldr-demo-release/dist && ./bldr-demo",
    "start:web": "npm run bldr -- --minify-entrypoint=false start web",
    "start:web:wasm": "npm run bldr -- --minify-entrypoint=false start web --wasm",
    "start:web:release": "npm run build:release:web && npm run bldr -- static --path ./.bldr/build/web/bldr-demo-release/dist",
    "start:web:release:debug": "npm run build:release:web:debug && npm run bldr -- static --path ./.bldr/build/web/bldr-demo-release/dist",
    "debug:native": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start native",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "build": "npm run bldr -- --build-type=debug build -b native",
    "build:web": "npm run bldr -- --build-type=debug build -b web",
    "build:release": "npm run bldr -- --build-type=release build -b release",
    "build:release:web": "npm run bldr -- --build-type=release build -b release-web",
    "build:release:web:debug": "npm run bldr -- --build-type=debug build -b release-web",
    "build:release:cross": "npm run bldr -- --build-type=release build -b release-cross",
    "build:release:debug": "npm run bldr -- --build-type=debug build -b release",
    "publish:release": "npm run bldr -- --build-type=release publish -p demo-dist",
    "dist": "npm run build:dist && npm run publish:release",
    "codegen": "npm run gen",
    "gen": "make genproto",
    "test": "make test && npm run check",
    "test:js": "echo No JS tests.",
    "format": "npm run format:go && npm run format:js && npm run format:config",
    "format:config": "prettier --write tsconfig.json package.json",
    "format:go": "make format",
    "format:js": "npm run format:js:changed",
    "format:js:changed": "git diff --name-only --diff-filter=d HEAD | grep '\\(\\.ts\\|\\.tsx\\|\\.html\\|\\.css\\|\\.scss\\)$' | grep '^\\(web\\|entrypoint\\|example\\)/' | xargs -I {} prettier --write {}",
    "format:js:all": "prettier --write './{web,entrypoint,example,prototypes}/**/(*.ts|*.tsx|*.html|*.css|*.scss)'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.js ./",
    "patch": "patch-package --use-yarn --patch-dir ./node_modules/@aperturerobotics/ts-common/patches",
    "precommit": "npm run format",
    "setup": "npm run bldr -- setup",
    "vendor": "go mod vendor",
    "prepare": "npm run patch && npm run clean && npm run vendor && npm run setup"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aperturerobotics/ts-common": "^0.9.1",
    "@types/lodash.isequal": "^4.5.8",
    "@types/random-string": "^0.0.31",
    "@types/react": "^18.2.75",
    "@types/react-dom": "^18.2.24",
    "cross-env": "^7.0.3",
    "enhanced-resolve": "^5.16.0",
    "esm-cjs-lexer": "^0.10.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.2.5",
    "pumpify": "^2.0.1",
    "rimraf": "^5.0.5",
    "ts-poet": "6.8.0",
    "ts-proto": "^1.171.0",
    "typescript": "^5.4.4",
    "unzip-crx-3": "^0.2.0"
  },
  "dependencies": {
    "@libp2p/logger": "^4.0.9",
    "browser-readablestream-to-it": "^2.0.5",
    "console": "^0.7.2",
    "electron": "^29.2.0",
    "event-iterator": "^2.0.0",
    "idb": "^8.0.0",
    "lodash.isequal": "^4.5.0",
    "long": "^5.2.1",
    "protobufjs": "^7.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "starpc": "^0.28.1",
    "workbox-window": "^7.0.0"
  }
}
