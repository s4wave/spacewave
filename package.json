{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run deps",
    "deps": "depcheck --ignores bufferutil,utf-8-validate,ts-proto,ts-poet,esbuild,protobufjs,@aperturerobotics/ts-common",
    "serve": "npm run start:web",
    "start": "npm run start:web",
    "start:electron": "rimraf ./.bldr && go run -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr start electron",
    "start:web": "rimraf ./.bldr && go run -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr start web",
    "start:web:wasm": "rimraf ./.bldr && go run -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr start web --wasm",
    "debug:electron": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start electron",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "codegen": "npm run gen",
    "gen": "make genproto",
    "test": "make test && npm run check",
    "test:js": "echo No JS tests.",
    "format": "prettier --write './{web,entrypoint,example}/**/(*.ts|*.tsx|*.html|*.css)'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./web",
    "patch": "patch-package --use-yarn --patch-dir ./node_modules/@aperturerobotics/ts-common/patches",
    "precommit": "npm run format",
    "setup": "go run -v -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr setup",
    "prepare": "npm run patch && go mod vendor && npm run setup"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aperturerobotics/ts-common": "0.3.3",
    "@types/random-string": "^0.0.28",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "depcheck": "^1.4.3",
    "electron": "^23.0.0",
    "eslint": "^8.33.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "patch-package": "^6.5.1",
    "prettier": "^2.8.3",
    "pumpify": "^2.0.1",
    "rimraf": "^4.1.2",
    "ts-poet": "^6.3.0",
    "ts-proto": "^1.139.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "@libp2p/logger": "^2.0.5",
    "@libp2p/mplex": "^7.1.1",
    "browser-readablestream-to-it": "^2.0.0",
    "console": "^0.7.2",
    "event-iterator": "^2.0.0",
    "idb": "^7.1.1",
    "it-first": "^2.0.0",
    "it-length-prefixed": "^8.0.4",
    "it-pipe": "^2.0.5",
    "it-pushable": "^3.1.2",
    "it-stream-types": "^1.0.5",
    "long": "^5.2.1",
    "protobufjs": "^7.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "starpc": "^0.18.0",
    "uint8arraylist": "^2.4.3",
    "workbox-window": "^6.5.4"
  }
}
