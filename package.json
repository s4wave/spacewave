{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperturerobotics.com",
    "url": "http://aperturerobotics.com"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperturerobotics.com",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "build": "snowpack build",
    "build:codegen": "npm run gen",
    "build:electron": "node ./scripts/build-electron-js",
    "build:gopherjs": "node ./scripts/build-runtime-gopherjs",
    "build:wasm": "node ./scripts/build-runtime-wasm",
    "codegen": "npm run gen",
    "debug:electron": "cd ./entrypoint/electron-dev && dlv debug",
    "format": "prettier --write './{src,target,entrypoint}/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "gen": "make genproto",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./src",
    "precommit": "lint-staged",
    "prepare": "husky install && snowpack prepare",
    "serve": "cd ./toys/serve && go run -v ./",
    "start": "npm run start:web",
    "start:electron": "npm run build:electron && cd ./entrypoint/electron-dev && go run -trimpath -v ./",
    "start:web": "snowpack dev",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,css,html}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "dependencies": {
    "@chakra-ui/react": "^1.8.7",
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@fontsource/open-sans": "^4.5.8",
    "@fontsource/raleway": "^4.5.5",
    "framer-motion": "^6.2.8",
    "geopattern": "^1.2.3",
    "protobufjs": "^6.11.2",
    "random-string": "^0.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^4.3.1",
    "rgraphql": "^1.0.4"
  },
  "devDependencies": {
    "@chakra-ui/theme-tools": "^1.3.6",
    "@snowpack/plugin-react-refresh": "^2.5.0",
    "@types/geopattern": "^1.2.6",
    "@types/random-string": "^0.0.28",
    "@types/react": "^17.0.43",
    "@types/react-dom": "^17.0.14",
    "@types/snowpack-env": "^2.3.4",
    "@typescript-eslint/eslint-plugin": "^5.17.0",
    "@typescript-eslint/parser": "^5.17.0",
    "electron": "^18.0.1",
    "eslint": "^8.12.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard-with-typescript": "^21.0.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.7",
    "prettier": "^2.6.2",
    "pumpify": "^2.0.1",
    "rimraf": "^3.0.2",
    "snowpack": "^3.8.8",
    "ts-proto": "^1.110.2",
    "typescript": "^4.6.3"
  }
}
