{
  "name": "@aperturerobotics/forge",
  "description": "Peer-to-peer build and data processing pipelines.",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/forge.git"
  },
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "typecheck": "tsc --project tsconfig.json --noEmit true",
    "deps": "depcheck --ignore-patterns=.eslintrc.cjs,package.json --ignores depcheck,@aptre/common,prettier,rimraf,typescript",
    "clean": "rimraf ./dist/",
    "build": "tsc --project tsconfig.json --noEmit false --outDir ./dist/",
    "codegen": "npm run gen",
    "gen": "npm run go:aptre -- generate",
    "gen:force": "npm run go:aptre -- generate --force",
    "format": "npm run format:js && npm run format:go",
    "format:go": "npm run go:aptre -- format",
    "format:js": "prettier --write './!(vendor|dist)/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "test": "npm run test:js && npm run test:go",
    "test:js": "npm run typecheck",
    "test:go": "npm run go:aptre -- test",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "npm run go:aptre -- lint",
    "lint:js": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.cjs ./",
    "ci": "npm run build && npm run lint:js && npm run lint:go",
    "prepare": "npm run clean && rimraf ./.tools && npm run vendor",
    "vendor": "go mod vendor",
    "go:aptre": "go run -mod=mod github.com/aperturerobotics/common/cmd/aptre",
    "precommit": "npm run format"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aptre/common": "^0.32.2",
    "depcheck": "^1.4.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "^1.0.2",
    "@aptre/v86": "^0.6.8",
    "it-pipe": "^3.0.1",
    "it-pushable": "^3.2.3",
    "starpc": "^0.49.2"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "0.5.2"
  }
}
