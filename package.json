{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/bldr.git"
  },
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint",
    "clean": "rimraf ./.bldr ./.bldr-dist",
    "go:run": "cross-env GOOS= GOARCH= go run -v -mod=readonly",
    "bldr": "bun run go:run -- github.com/aperturerobotics/bldr/cmd/bldr --bldr-src-path=../../",
    "serve": "bun run start:web",
    "start": "bun run start:web",
    "start:native": "bun run bldr -- start native",
    "start:native:release": "bun run build:release && cd ./.bldr/build/native/$(go env GOOS)/$(go env GOARCH)/bldr-demo-release/dist && ./bldr-demo",
    "start:web": "bun run bldr -- --minify-entrypoint=false start web",
    "start:web:wasm": "bun run bldr -- --minify-entrypoint=false start web --wasm",
    "start:web:wasm:browser": "node scripts/start-web-wasm-browser.js",
    "start:web:release": "bun run build:release:web && bun run bldr -- static --path ./.bldr-dist/build/native/js/wasm/bldr-demo-release/dist",
    "start:web:release:debug": "bun run build:release:web:debug && bun run bldr -- static --path ./.bldr-dist/build/native/js/wasm/bldr-demo-release/dist",
    "debug:native": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start native",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "debug:web:wasm": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web --wasm",
    "debug:release:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false --build-type=debug build -b release-web",
    "build": "bun run bldr -- --build-type=debug build -b native",
    "build:web": "bun run bldr -- --build-type=debug build -b web",
    "build:release": "bun run bldr -- --build-type=release build -b release",
    "build:release:web": "bun run bldr -- --state-path=.bldr-dist --build-type=release build -b release-web",
    "build:release:web:debug": "bun run bldr -- --state-path=.bldr-dist --build-type=debug build -b release-web",
    "build:release:cross": "bun run bldr -- --build-type=release build -b release-cross",
    "build:release:debug": "bun run bldr -- --build-type=debug build -b release",
    "publish:release": "bun run bldr -- --build-type=release publish -p demo-dist",
    "dist": "bun run build:release:web && bun run publish:release",
    "codegen": "bun run gen",
    "gen": "bun run gen:proto && bun run gen:deps && bun run gen:go",
    "gen:proto": "make genproto",
    "gen:deps": "bun -e \"const pkg = require('./package.json'); const distPkg = require('./dist/deps/package.json'); Object.entries(pkg.dependencies).forEach(([name, version]) => { if (distPkg.dependencies[name]) { distPkg.dependencies[name] = version; } }); Object.entries(pkg.resolutions).forEach(([name, version]) => { distPkg.resolutions[name] = version.replace(/^\\^/, ''); }); require('fs').writeFileSync('./dist/deps/package.json', JSON.stringify(distPkg, null, 2));\" && cd ./dist/deps && bun i",
    "gen:go": "go generate ./...",
    "format": "bun run format:js && bun run format:go && bun run format:config",
    "format:config": "prettier --write '*.json' '.github/**/*.json' '.prettierrc.yaml'",
    "format:go": "make format",
    "format:js": "bun run format:js:changed",
    "format:js:changed": "git diff --name-only --diff-filter=d HEAD | grep '\\(\\.ts\\|\\.tsx\\|\\.html\\|\\.css\\|\\.scss\\)$' | grep '^\\(web\\|entrypoint\\|example\\|prototypes\\|util\\|sdk\\|plugin\\)/' | xargs -I {} prettier --write {}",
    "format:js:all": "prettier --write './{web,entrypoint,example,prototypes,util,sdk,plugin}/**/(*.ts|*.tsx|*.html|*.css|*.scss)'",
    "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json",
    "test": "bun run test:js && bun run test:go",
    "test:js": "vitest run && bun run typecheck",
    "test:release:web": "bun run build:release:web && playwright test --config web/entrypoint/browser/playwright.config.ts",
    "test:go": "make test",
    "lint": "bun run lint:go && bun run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c eslintrc.config.mjs ./",
    "precommit": "bun run format",
    "setup": "bun run bldr -- setup",
    "vendor": "go mod vendor",
    "prepare": "bun run clean && rimraf ./.tools && bun run vendor && bun run setup"
  },
  "devDependencies": {
    "@aptre-cjs/esm-cjs-lexer": "^0.1.0",
    "@aptre/common": "^0.24.0",
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.5",
    "@types/random-string": "^0.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260106.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.15",
    "cross-env": "^10.0.0",
    "enhanced-resolve": "^5.18.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.0.11",
    "lucide-react": "^0.562.0",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "pumpify": "^2.0.1",
    "rimraf": "^6.1.2",
    "rollup": "^4.55.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.52.0",
    "unzip-crx-3": "^0.2.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "^0.5.2",
    "@libp2p/logger": "^6.2.2",
    "console": "^0.7.2",
    "electron": "^39.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "starpc": "^0.41.2",
    "workbox-window": "^7.4.0"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "0.5.2",
    "@libp2p/interface": "^2.6.1"
  }
}
