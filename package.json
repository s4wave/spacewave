{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/bldr.git"
  },
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "clean": "rimraf ./.bldr",
    "bldr": "go run -v -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr",
    "serve": "npm run start:web",
    "start": "npm run start:web",
    "start:native": "npm run bldr -- start native",
    "start:web": "npm run bldr -- start web",
    "start:web:wasm": "npm run bldr -- start web --wasm",
    "debug:native": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start native",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "build": "npm run bldr -- --disable-cleanup build -b dist",
    "build:release": "npm run bldr -- --build-type=release build -b dist",
    "build:cross": "npm run bldr -- --build-type=release build -b cross",
    "publish:release": "npm run bldr -- --build-type=release publish -p demo-dist",
    "dist": "npm run build:release && npm run publish:release",
    "codegen": "npm run gen",
    "gen": "make genproto",
    "test": "make test && npm run check",
    "test:js": "echo No JS tests.",
    "format": "npm run format:changed",
    "format:changed": "git diff --name-only --diff-filter=d HEAD | grep '\\(\\.ts\\|\\.tsx\\|\\.html\\|\\.css\\|\\.scss\\)$' | grep '^\\(web\\|entrypoint\\|example\\)/' | xargs -I {} prettier --write {}",
    "format:config": "prettier --write tsconfig.json package.json",
    "format:all": "prettier --write './{web,entrypoint,example}/**/(*.ts|*.tsx|*.html|*.css|*.scss)' && npm run format:config",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js './web/**/*.{js,ts,tsx}'",
    "patch": "patch-package --use-yarn --patch-dir ./node_modules/@aperturerobotics/ts-common/patches",
    "precommit": "npm run format",
    "setup": "npm run bldr -- setup",
    "vendor": "go mod vendor",
    "prepare": "npm run patch && npm run clean && npm run vendor && npm run setup"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aperturerobotics/ts-common": "^0.8.0",
    "@types/random-string": "^0.0.31",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "enhanced-resolve": "^5.15.0",
    "esm-cjs-lexer": "^0.9.1",
    "patch-package": "^8.0.0",
    "prettier": "^3.1.1",
    "pumpify": "^2.0.1",
    "rimraf": "^5.0.5",
    "ts-poet": "6.6.0",
    "ts-proto": "^1.165.2",
    "typescript": "^5.3.3",
    "unzip-crx-3": "^0.2.0"
  },
  "dependencies": {
    "@libp2p/logger": "^4.0.2",
    "browser-readablestream-to-it": "^2.0.5",
    "console": "^0.7.2",
    "electron": "^28.0.0",
    "event-iterator": "^2.0.0",
    "idb": "^8.0.0",
    "long": "^5.2.1",
    "protobufjs": "^7.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "starpc": "^0.22.0",
    "uint8arraylist": "^2.4.7",
    "workbox-window": "^7.0.0"
  }
}
