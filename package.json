{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "build": "snowpack build",
    "build:codegen": "npm run gen",
    "build:electron": "node ./scripts/build-electron-js",
    "build:gopherjs": "node ./scripts/build-runtime-gopherjs",
    "build:wasm": "node ./scripts/build-runtime-wasm",
    "codegen": "npm run gen",
    "debug:electron": "cd ./entrypoint/electron-dev && dlv debug",
    "format": "prettier --write './web/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "gen": "make genproto",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./src",
    "precommit": "npm run format",
    "prepare": "husky install && patch-package && snowpack prepare && go mod vendor",
    "serve": "cd ./toys/serve && go run -v ./",
    "start": "npm run start:web",
    "start:electron": "npm run build:electron && cd ./entrypoint/electron-dev && go run -trimpath -v ./",
    "start:web": "snowpack dev",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "devDependencies": {
    "@snowpack/plugin-react-refresh": "^2.5.0",
    "@types/geopattern": "^1.2.6",
    "@types/random-string": "^0.0.28",
    "@types/react": "^18.0.9",
    "@types/react-dom": "^18.0.4",
    "@types/snowpack-env": "^2.3.4",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
    "@typescript-eslint/parser": "^5.25.0",
    "electron": "^18.2.4",
    "eslint": "^8.16.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard-with-typescript": "^21.0.1",
    "eslint-plugin-react-hooks": "^4.5.0",
    "husky": "^8.0.1",
    "patch-package": "^6.4.7",
    "prettier": "^2.6.2",
    "pumpify": "^2.0.1",
    "rimraf": "^3.0.2",
    "snowpack": "^3.8.8",
    "ts-poet": "^4.13.0",
    "ts-proto": "^1.112.2",
    "typescript": "^4.6.4"
  },
  "dependencies": {
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@fontsource/open-sans": "^4.5.10",
    "@fontsource/raleway": "^4.5.8",
    "event-iterator": "^2.0.0",
    "framer-motion": "^6.3.3",
    "geopattern": "^1.2.3",
    "idb": "^7.0.1",
    "protobufjs": "^6.11.3",
    "random-string": "^0.2.0",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-icons": "^4.3.1",
    "rxjs": "^7.5.5",
    "starpc": "^0.1.6"
  }
}
