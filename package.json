{
  "name": "spacewave",
  "description": "spacewave monorepo",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/s4wave/spacewave.git"
  },
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint",
    "build:net": "tsgo --project tsconfig.json --noEmit false --outDir ./dist/",
    "clean": "rimraf ./dist ./.tools",
    "clean:full": "bun run clean && rimraf ./.tmp",
    "build": "bun run build:net",
    "codegen": "bun run gen",
    "format": "bun run format:js && bun run format:go && bun run format:config",
    "format:config": "prettier --write '*.json' '.github/**/*.json' '.github/**/*.yml' '.prettierrc.yaml' '.golangci.yml' 'tsconfig.json'",
    "format:go": "bun run go:aptre -- format && go fix ./...",
    "format:js": "prettier --write './net/**/(*.ts|*.tsx|*.js|*.html|*.css|*.scss)' && bun run format:config",
    "gen": "bun run go:aptre -- generate",
    "gen:force": "bun run go:aptre -- generate --force",
    "go:aptre": "go run -mod=mod github.com/aperturerobotics/common/cmd/aptre",
    "lint": "bun run lint:js && bun run lint:go",
    "lint:go:db": "bun run go:aptre -- lint ./db/...",
    "lint:go:net": "bun run go:aptre -- lint ./net/...",
    "lint:go": "bun run go:aptre -- lint",
    "lint:js:db": "eslint --no-warn-ignored ./db --ext .ts",
    "lint:js:net": "eslint --no-warn-ignored ./net --ext .ts",
    "lint:js": "eslint . --ext .js,.mjs,.ts,.tsx",
    "lint:js:fix": "bun run lint:js -- --fix",
    "precommit": "bun run format",
    "prepare": "go mod vendor && rimraf ./.tools",
    "test": "bun run test:js && bun run test:go && bun run check",
    "test:go:db": "bun run go:aptre -- test ./db/...",
    "test:go:net": "bun run go:aptre -- test ./net/...",
    "test:go": "bun run go:aptre -- test",
    "test:js:db": "bun test ./db/**/*.test.ts",
    "test:js:net": "echo No JS tests in net.",
    "test:js": "echo No JS tests.",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@aptre/common": "^0.32.4",
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260420.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "^1.0.0",
    "starpc": "^0.49.0"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "^1.0.0"
  }
}
