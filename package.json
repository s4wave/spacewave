{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git@github.com:aperturerobotics/bldr.git"
  },
  "scripts": {
    "build": "npm run build:electron && make entrypoint && npm run build:web",
    "build:codegen": "npm run gen",
    "build:web": "node ./scripts/build-browser",
    "build:gopherjs": "node ./scripts/build-runtime-gopherjs",
    "build:wasm": "node ./scripts/build-runtime-wasm",
    "check": "npm run typecheck && npm run lint && npm run deps",
    "deps": "depcheck --ignores bufferutil,utf-8-validate,ts-proto,ts-poet,esbuild,protobufjs,@aperturerobotics/ts-common",
    "serve": "node ./scripts/serve-browser",
    "start": "npm run start:web",
    "start:electron": "go run -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr --minify-entrypoint=false start electron",
    "start:web": "go run -mod=readonly github.com/aperturerobotics/bldr/cmd/bldr --minify-entrypoint=false start web",
    "debug:electron": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start electron",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "codegen": "npm run gen",
    "gen": "make genproto",
    "test": "make test && npm run check",
    "test:js": "echo No JS tests.",
    "format": "prettier --write './{web,entrypoint}/**/(*.ts|*.tsx|*.html|*.css)'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c .eslintrc.js --ext .ts ./web",
    "patch": "patch-package --use-yarn --patch-dir ./node_modules/@aperturerobotics/ts-common/patches",
    "precommit": "npm run format",
    "prepare": "npm run patch && go mod vendor"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aperturerobotics/ts-common": "0.2.4",
    "@types/random-string": "^0.0.28",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "depcheck": "^1.4.3",
    "electron": "^21.1.1",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-standard-with-typescript": "^23.0.0",
    "patch-package": "^6.4.7",
    "prettier": "^2.7.1",
    "pumpify": "^2.0.1",
    "ts-poet": "^6.1.0",
    "ts-proto": "^1.129.0",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "@libp2p/logger": "^2.0.2",
    "@libp2p/mplex": "^7.0.0",
    "browser-readablestream-to-it": "^1.0.3",
    "console": "^0.7.2",
    "event-iterator": "^2.0.0",
    "idb": "^7.1.0",
    "it-first": "^1.0.7",
    "it-length-prefixed": "^8.0.3",
    "it-pipe": "^2.0.4",
    "it-pushable": "^3.1.0",
    "it-stream-types": "^1.0.4",
    "long": "^5.2.0",
    "protobufjs": "^7.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "starpc": "^0.12.2",
    "uint8arraylist": "^2.3.3",
    "workbox-window": "^6.5.4"
  }
}
