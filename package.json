{
  "name": "@aperturerobotics/bldr",
  "description": "application bundler and user interface toolkit",
  "version": "0.0.0-dev",
  "private": true,
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/bldr.git"
  },
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "clean": "rimraf ./.bldr",
    "go:run": "cross-env GOOS= GOARCH= go run -v -mod=readonly",
    "bldr": "npm run go:run -- github.com/aperturerobotics/bldr/cmd/bldr --bldr-src-path=../../",
    "serve": "npm run start:web",
    "start": "npm run start:web",
    "start:native": "npm run bldr -- start native",
    "start:native:release": "npm run build:release && cd ./.bldr/build/native/bldr-demo-release/dist && ./bldr-demo",
    "start:web": "npm run bldr -- --minify-entrypoint=false start web",
    "start:web:wasm": "npm run bldr -- --minify-entrypoint=false start web --wasm",
    "start:web:release": "npm run build:release:web && npm run bldr -- static --path ./.bldr/build/web/bldr-demo-release/dist",
    "start:web:release:debug": "npm run build:release:web:debug && npm run bldr -- static --path ./.bldr/build/web/bldr-demo-release/dist",
    "debug:native": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start native",
    "debug:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web",
    "debug:web:wasm": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false start web --wasm",
    "debug:release:web": "cd ./cmd/bldr && dlv debug --wd ../../ -- --minify-entrypoint=false --build-type=debug build -b release-web",
    "build": "npm run bldr -- --build-type=debug build -b native",
    "build:web": "npm run bldr -- --build-type=debug build -b web",
    "build:release": "npm run bldr -- --build-type=release build -b release",
    "build:release:web": "npm run bldr -- --build-type=release build -b release-web",
    "build:release:web:debug": "npm run bldr -- --build-type=debug build -b release-web",
    "build:release:cross": "npm run bldr -- --build-type=release build -b release-cross",
    "build:release:debug": "npm run bldr -- --build-type=debug build -b release",
    "publish:release": "npm run bldr -- --build-type=release publish -p demo-dist",
    "dist": "npm run build:release:web && npm run publish:release",
    "codegen": "npm run gen",
    "gen": "npm run gen:proto && npm run gen:deps && npm run gen:go",
    "gen:proto": "make genproto",
    "gen:deps": "node -e \"const pkg = require('./package.json'); const distPkg = require('./dist/deps/package.json'); Object.entries(pkg.dependencies).forEach(([name, version]) => { if (distPkg.dependencies[name]) { distPkg.dependencies[name] = version; } }); Object.entries(pkg.resolutions).forEach(([name, version]) => { distPkg.resolutions[name] = version.replace(/^\\^/, ''); }); require('fs').writeFileSync('./dist/deps/package.json', JSON.stringify(distPkg, null, 2));\" && cd ./dist/deps && npm i --package-lock-only",
    "gen:go": "go generate ./...",
    "format": "npm run format:js && npm run format:go && npm run format:config",
    "format:config": "prettier --write tsconfig.json package.json",
    "format:go": "make format",
    "format:js": "npm run format:js:changed",
    "format:js:changed": "git diff --name-only --diff-filter=d HEAD | grep '\\(\\.ts\\|\\.tsx\\|\\.html\\|\\.css\\|\\.scss\\)$' | grep '^\\(web\\|entrypoint\\|example\\|prototypes\\|util\\|sdk\\|plugin\\)/' | xargs -I {} prettier --write {}",
    "format:js:all": "prettier --write './{web,entrypoint,example,prototypes,util,sdk,plugin}/**/(*.ts|*.tsx|*.html|*.css|*.scss)'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npm run test:js && npm run test:go",
    "test:js": "vitest run && npm run typecheck",
    "test:go": "make test",
    "lint": "npm run lint:go && npm run lint:js",
    "lint:go": "make lint",
    "lint:js": "eslint -c eslintrc.config.mjs ./",
    "precommit": "npm run format",
    "setup": "npm run bldr -- setup",
    "vendor": "go mod vendor",
    "prepare": "npm run clean && rimraf ./.tools && npm run vendor && npm run setup"
  },
  "devDependencies": {
    "@aptre-cjs/esm-cjs-lexer": "^0.1.0",
    "@aptre/common": "^0.22.12",
    "@types/random-string": "^0.2.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "cross-env": "^10.0.0",
    "enhanced-resolve": "^5.18.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^18.0.1",
    "lucide-react": "^0.544.0",
    "prettier": "^3.6.2",
    "pumpify": "^2.0.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "unzip-crx-3": "^0.2.0",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "^0.5.2",
    "@libp2p/logger": "^5.2.0",
    "console": "^0.7.2",
    "electron": "^38.1.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "starpc": "^0.39.9",
    "workbox-window": "^7.3.0"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "0.5.2"
  }
}
