{
  "extends": ["tslint:recommended", "tslint-react", "tslint-config-prettier"],
  "linterOptions": {
    "exclude": [
      "dist/**/*.js",
      "webpack.config.js",
      "bundle/**/*.js",
      "runtime/**/*.js",
      "node_modules/**/*.ts"
    ]
  },
  "rules": {
    "no-empty-interface": false
  }
}
