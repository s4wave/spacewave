{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "node",
    "jsx": "preserve",
    "baseUrl": "./",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "importsNotUsedAsValues": "remove",
    "esModuleInterop": true,
    "lib": [
      "webworker",
      "dom"
    ],
    "paths": {
      "@protobufjs/inquire": ["./fixups/protobufjs/inquire.js"]
    }
  },
  "include": [
    "web"
  ]
}
