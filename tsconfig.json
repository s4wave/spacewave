{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2024", "webworker", "dom"],
    "paths": {
      "@go/*": ["./vendor/*"],
      "@s4wave/net/*": ["./net/*"],
      "@s4wave/net": ["./net"]
    }
  },
  "include": ["net/**/*.ts"],
  "exclude": ["node_modules", "vendor", "dist"]
}
