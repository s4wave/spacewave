{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "@go/*": ["./vendor/*"],
      "@aptre/bldr": ["./web/bldr/index.js"],
      "@aptre/bldr-react": ["./web/bldr-react/index.js"],
      "@aptre/bldr-sdk": ["./sdk/plugin.ts"],
      "@aptre/bldr-sdk/*": ["./sdk/*"]
    },
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importsNotUsedAsValues": "remove",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["webworker", "dom"]
  },
  "exclude": ["node_modules", "vendor", "dist"]
}
