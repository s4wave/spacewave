{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2024", "webworker", "dom"],
    "paths": {
      "@go/*": ["./vendor/*"]
    }
  },
  "exclude": [
    "node_modules",
    "vendor",
    "dist",
    ".bldr",
    ".bldr-dist"
  ]
}
